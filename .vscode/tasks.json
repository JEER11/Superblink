{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "PIO: Build Blink",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"platformio",
				"run",
				"-e",
				"hifive1-revb"
			],
			"group": "build",
			"problemMatcher": ["$gcc"]
		},
        {
            "label": "PIO: Build Lab1 ASM",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": ["-m", "platformio", "run", "-e", "lab1-asm"],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "PIO: Upload Lab1 ASM",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": ["-m", "platformio", "run", "-e", "lab1-asm", "-t", "upload"],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
		{
			"label": "PIO: Build Lab1 ASM Part 2",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": ["-m", "platformio", "run", "-e", "lab1-asm-part2"],
			"group": "build",
			"problemMatcher": ["$gcc"]
		},
		{
			"label": "PIO: Upload Lab1 ASM Part 2",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": ["-m", "platformio", "run", "-e", "lab1-asm-part2", "-t", "upload"],
			"group": "build",
			"problemMatcher": ["$gcc"]
		},
		{
			"label": "PIO: Build Lab1 ASM Part 3",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": ["-m", "platformio", "run", "-e", "lab1-asm-part3"],
			"group": "build",
			"problemMatcher": ["$gcc"]
		},
		{
			"label": "PIO: Upload Lab1 ASM Part 3",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": ["-m", "platformio", "run", "-e", "lab1-asm-part3", "-t", "upload"],
			"group": "build",
			"problemMatcher": ["$gcc"]
		},
		{
			"label": "PIO: Upload Blink",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"platformio",
				"run",
				"-e",
				"hifive1-revb",
				"-t",
				"upload"
			],
			"group": "build",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "PIO: Build Lab1 UART",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"platformio",
				"run",
				"-e",
				"lab1-uart"
			],
			"group": "build",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "PIO: Upload Lab1 UART",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"platformio",
				"run",
				"-e",
				"lab1-uart",
				"-t",
				"upload"
			],
			"group": "build",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "PIO: Monitor 115200",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"platformio",
				"device",
				"monitor",
				"--baud",
				"115200"
			],
			"isBackground": true
		},
		{
			"label": "PIO upload blink (venv)",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"platformio",
				"run",
				"-e",
				"hifive1-revb",
				"-t",
				"upload"
			],
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		}
	]
}